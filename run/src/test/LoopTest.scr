package test;

class LoopTest {

    static void testIteration(String[] args) {
        for (String s : args) {
            System.print(s);
        }
    }

    static void testI() {
        for (int i = 0; i < 100; i++) {
            System.print(i);
        }
    }

    static void testWhile() {
        int i = 0;
        while (i < 100) {
            System.print(i);
            i++;
        }
    }

    static void testEnclosed() {
        for (int i = -4; i < 5; i++) {
            for (int j = -4; j < 5; j++) {
                if (14 < i * i + j * j < 16) {
                    System.print(i);
                    System.print(j);
                }
            }
        }
    }

    static void main(String[] args) {
        //testIteration(args);
        //testI();
        //testWhile();
        testEnclosed();
    }
}
