package test;

class SumTest {

    static void main(String[] args) {
        int s = 0;
        for (int i = 1; i <= 100; i++) {
            s += i;
        }
        System.print(s);
    }

    static int sum(int n) {
        int sum = 0;
        for (int i = 0; i <= n; i++) {
            sum += i;
        }
        return sum;
    }

    static int quadSum(int n) {
        int sum = 0;
        for (int i = 0; i <= n; i++) {
            sum += i**2;
        }
        return sum;
    }
}